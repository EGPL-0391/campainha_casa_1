<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Aguarde — Morador sendo contactado</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background-color: #166534;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      padding: 2rem;
      text-align: center;
    }

    .icon {
      font-size: 80px;
      margin-bottom: 2rem;
      animation: bounce 1.5s infinite;
    }

    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }

    h1 {
      color: #ffffff;
      font-size: clamp(1.6rem, 5vw, 2.4rem);
      font-weight: 700;
      line-height: 1.3;
      margin-bottom: 1rem;
    }

    p {
      color: rgba(255, 255, 255, 0.85);
      font-size: clamp(1rem, 3vw, 1.25rem);
      line-height: 1.6;
    }

    .card {
      background: rgba(255, 255, 255, 0.12);
      border-radius: 20px;
      padding: 2.5rem 2rem;
      max-width: 420px;
      width: 100%;
      border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .status {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(255,255,255,0.15);
      border-radius: 50px;
      padding: 6px 16px;
      margin-top: 1.5rem;
      font-size: 0.85rem;
      color: rgba(255,255,255,0.9);
    }

    .dot {
      width: 8px;
      height: 8px;
      background: #4ade80;
      border-radius: 50%;
      animation: blink 1s infinite;
    }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }

    #status-msg { display: none; margin-top: 1rem; font-size: 0.8rem; color: rgba(255,255,255,0.5); }
    #error-msg { display: none; margin-top: 1rem; font-size: 0.85rem; color: #fca5a5; background: rgba(255,0,0,0.1); padding: 8px 14px; border-radius: 8px; }
  </style>
</head>
<body>

  <div class="card">
    <div class="icon">🔔</div>

    <h1>Por favor, aguarde um minuto!</h1>
    <p>O morador já foi contactado.</p>

    <div class="status">
      <div class="dot"></div>
      Aviso enviado
    </div>

    <div id="status-msg"></div>
    <div id="error-msg"></div>
  </div>

  <script>
    // =====================================================
    //  CONFIGURAÇÃO — altere apenas estas linhas
    // =====================================================
    const TOPICO = "campainha_casa_1"; // Escolha um nome único e secreto
    const MENSAGEM = "Alguém está na portaria!";
    const TITULO = "🔔 CAMPAINHA";
    // =====================================================

    const NTFY_URL = `https://ntfy.sh/${campainha_casa_1}`;

    async function enviarNotificacao() {
      try {
        const resposta = await fetch(NTFY_URL, {
          method: "POST",
          headers: {
            "Title": TITULO,
            "Priority": "urgent",
            "Tags": "bell,rotating_light",
            "Content-Type": "text/plain"
          },
          body: MENSAGEM
        });

        if (!resposta.ok) {
          throw new Error(`Erro HTTP: ${resposta.status}`);
        }

        console.log("Notificação enviada com sucesso.");
      } catch (err) {
        console.error("Falha ao enviar notificação:", err);
        const el = document.getElementById("error-msg");
        el.textContent = "Não foi possível enviar o aviso. Verifique sua conexão.";
        el.style.display = "block";
      }
    }

    // Envia assim que o visitante abre a página
    enviarNotificacao();
  </script>

</body>
</html>
